# AWS Config
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET

# Project
PROJECT_NAME=enterprise-url-shortener
CUSTOM_DOMAIN=example.com
ENABLE_ANALYTICS=true

# DynamoDB
TABLE_NAME=enterprise-url-shortener-table

# API Gateway
API_BASE=https://replace-with-your-api-id.execute-api.ap-south-1.amazonaws.com

# S3 / CloudFront
FRONTEND_BUCKET=enterprise-url-shortener-frontend